---
/**
 * InteractiveChecklist.astro
 * Interactive problem checklist with progress tracking
 * Used on homepage for Arrays & Hashing roadmap preview
 */

interface Problem {
  number: number;
  title: string;
  slug: string;
  difficulty: "Easy" | "Medium" | "Hard";
  solved?: boolean;
}

interface Props {
  title?: string;
  problems: Problem[];
}

const { title = "Arrays & Hashing", problems = [] } = Astro.props;
const solved = problems.filter((p) => p.solved).length;
const total = problems.length;
const percentage = total > 0 ? Math.round((solved / total) * 100) : 0;

function getDifficultyClass(difficulty: string): string {
  switch (difficulty) {
    case "Medium":
      return "medium";
    case "Hard":
      return "hard";
    default:
      return "easy";
  }
}
---

<div class="lc-checklist-section">
  <h3 style="margin-top: 2rem; margin-bottom: 1rem; font-size: 1.1rem;">
    {title}
  </h3>

  <div class="lc-checklist">
    {problems.map((problem) => (
      <a
        href={`/leetcode_solutions/problems/${problem.slug}/`}
        class="lc-checklist-item"
        title={`#${problem.number} ${problem.title}`}
      >
        <input
          type="checkbox"
          checked={problem.solved}
          readonly
          aria-label={`Mark ${problem.title} as ${problem.solved ? "incomplete" : "complete"}`}
        />
        <span class="lc-checklist-item-number">#{problem.number}</span>
        <span class="lc-checklist-item-title">{problem.title}</span>
        <span class={`lc-checklist-item-difficulty lc-checklist-item-difficulty--${getDifficultyClass(problem.difficulty)}`}>
          {problem.difficulty}
        </span>
      </a>
    ))}
  </div>

  <div class="lc-progress-bar">
    <div
      class="lc-progress-bar-fill"
      style={`width: ${percentage}%`}
    ></div>
  </div>

  <div class="lc-progress-text">
    {solved} of {total} problems completed ({percentage}%)
  </div>
</div>

<style>
  .lc-checklist-section {
    margin: 2rem 0;
  }

  .lc-checklist {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .lc-checklist-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: var(--lc-radius-md);
    background: color-mix(in srgb, var(--sl-color-accent) 5%, transparent);
    border: 1px solid var(--sl-color-hairline);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .lc-checklist-item:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    transform: translateX(4px);
  }

  .lc-checklist-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--sl-color-accent);
    flex-shrink: 0;
  }

  .lc-checklist-item-number {
    font-weight: 600;
    color: var(--sl-color-accent);
    min-width: 2.5rem;
    font-size: 0.9rem;
  }

  .lc-checklist-item-title {
    flex: 1;
  }

  .lc-checklist-item-difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .lc-checklist-item-difficulty--easy {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
  }

  .lc-checklist-item-difficulty--medium {
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    color: #fbbf24;
  }

  .lc-checklist-item-difficulty--hard {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #f87171;
  }

  .lc-progress-bar {
    width: 100%;
    height: 8px;
    background: var(--sl-color-gray-6);
    border-radius: 100px;
    overflow: hidden;
    margin-top: 1rem;
  }

  .lc-progress-bar-fill {
    height: 100%;
    background: var(--lc-grad);
    border-radius: 100px;
    transition: width 0.3s ease;
  }

  .lc-progress-text {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin-top: 0.5rem;
    font-weight: 500;
  }

  @media (max-width: 767px) {
    .lc-checklist-item {
      padding: 0.6rem 0.75rem;
      flex-wrap: wrap;
    }

    .lc-checklist-item-title {
      flex: 1;
      min-width: 0;
    }
  }

  @media (max-width: 479px) {
    .lc-checklist-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .lc-checklist-item-number {
      min-width: auto;
    }
  }
</style>
